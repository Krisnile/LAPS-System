# True for development, False for production
DEBUG=True

SECRET_KEY=<STRONG_KEY_HERE>

# PostgreSQL（必填安装并创建库）
# Linux/apt 常用 DB_USERNAME=postgres；macOS Homebrew 常用「终端执行 whoami 得到的用户名」，不要写 whoami 这六个字母
DB_NAME=laps
DB_USERNAME=postgres
DB_PASS=
DB_HOST=localhost
DB_PORT=5432
# 若使用 DB_USER 而非 DB_USERNAME，二者选其一即可
